<?xml version="1.0" encoding="utf-8"?>
<odoo>

     <!-- Vista Tree -->
    <record id="view_list_administradora_tree" model="ir.ui.view">
        <field name="name">list.administradora.tree</field>
        <field name="model">list.administradoras</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type_entity"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Vista Form -->
    <record id="view_hr_administradora_form" model="ir.ui.view">
        <field name="name">list.administradora.form</field>
        <field name="model">list.administradoras</field>
        <field name="arch" type="xml">
            <form string="Listado de Administradora">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="type_entity"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Acción -->
    <record id="action_hr_administradora" model="ir.actions.act_window">
        <field name="name">Listado de Administradoras</field>
        <field name="res_model">list.administradoras</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>
                Cree y administre las administradoras usadas en el contrato.
            </p>
        </field>
    </record>

    <!-- Menú (Configuración Nómina) -->
    <menuitem
        id="menu_hr_administradora"
        name="Administradoras"
        parent="hr_payroll.menu_hr_payroll_global_settings"
        action="action_hr_administradora"
        sequence="30"
    />

</odoo>
