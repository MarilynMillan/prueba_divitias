<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_administradoras_form_inherit_endowment" model="ir.ui.view">
        <field name="name">hr.administradoras.form.inherit.endowment</field>
        <field name="model">hr.administradoras</field>
        <field name="inherit_id" ref="fix_extructuras_de_pago.administradoras_forma"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='cuenta_credito']" position="after">
                <field name="type_entity"/>
                <field name="show_ccf" invisible="1"/>
                <field name="list_administradora_id" attrs="{'invisible': [('type_entity', '=', False)]}"/>
                <field name="tarifa" attrs="{'invisible': [('type_entity', '!=', 'salud'), ('type_entity', '!=', 'pension'), ('type_entity', '!=', 'arl')]}"/>
                <field name="tarifa_sena" attrs="{'invisible': [('show_ccf', '=', False)]}"/>
                <field name="tarifa_icbf" attrs="{'invisible': [('show_ccf', '=', False)]}"/>
                <field name="tarifa_esap" attrs="{'invisible': [('show_ccf', '=', False)]}"/>
                <field name="tarifa_men" attrs="{'invisible': [('show_ccf', '=', False)]}"/>
                <field name="traslado"/>
                <field name="list_administradora_destino_id" attrs="{'invisible': [('traslado', '=', False)]}"/>
                <field name="contract_id" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_administradoras_list_inherit_endowment" model="ir.ui.view">
        <field name="name">hr.administradoras.list.inherit.endowment</field>
        <field name="model">hr.administradoras</field>
        <field name="inherit_id" ref="fix_extructuras_de_pago.administradoras_lista"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='cuenta_credito']" position="after">
                <field name="type_entity"/>
                <field name="list_administradora_id"/>
                <field name="tarifa"/>
                <field name="traslado"/>
            </xpath>
        </field>
    </record>
</odoo>
