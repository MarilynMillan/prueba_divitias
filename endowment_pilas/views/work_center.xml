<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_work_center_tree" model="ir.ui.view">
        <field name="name">hr.work.center.tree</field>
        <field name="model">hr.work.center</field>
        <field name="arch" type="xml">
            <list string="Centros de Trabajo">
                <field name="code"/>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_hr_work_center_form" model="ir.ui.view">
        <field name="name">hr.work.center.form</field>
        <field name="model">hr.work.center</field>
        <field name="arch" type="xml">
            <form string="Centro de Trabajo">
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="Ej: RIESGO III"/>
                            <field name="code" placeholder="Ej: CT-001"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                            <field name="active" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_work_center" model="ir.actions.act_window">
        <field name="name">Centros de Trabajo</field>
        <field name="res_model">hr.work.center</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Centro de Trabajo
            </p>
        </field>
    </record>

    <menuitem
        id="menu_hr_work_center_config"
        name="Centros de Trabajo"
        parent="hr_payroll.menu_hr_payroll_global_settings"
        action="action_hr_work_center"
        sequence="40"/>
</odoo>