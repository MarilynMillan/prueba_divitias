<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_worker_type_tree" model="ir.ui.view">
        <field name="name">hr.worker.type.tree</field>
        <field name="model">hr.worker.type</field>
        <field name="arch" type="xml">
            <tree string="Tipos de Trabajador">
                <field name="code"/>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_worker_type_form" model="ir.ui.view">
        <field name="name">hr.worker.type.form</field>
        <field name="model">hr.worker.type</field>
        <field name="arch" type="xml">
            <form string="Tipo de Trabajador">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_worker_type" model="ir.actions.act_window">
        <field name="name">Tipos de Trabajador (PILA)</field>
        <field name="res_model">hr.worker.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_hr_worker_type"
              name="Tipos de Trabajador"
              parent="hr_payroll.menu_hr_payroll_configuration"
              action="action_hr_worker_type"
              sequence="41"/>
</odoo>
