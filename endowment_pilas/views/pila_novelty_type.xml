<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="pila_novelty_type_view_tree" model="ir.ui.view">
            <field name="name">pila.novelty.type.view.tree</field>
            <field name="model">pila.novelty.type</field>
            <field name="arch" type="xml">
                <list string="Tipos de Novedad">
                        <field name="code"/> 
                        <field name="name"/> 
                        <field name="description"/> 
                </list>
            </field>
        </record>

        <record id="pila_novelty_type_view_form" model="ir.ui.view">
            <field name="name">pila.novelty.type.view.form</field>
            <field name="model">pila.novelty.type</field>
            <field name="arch" type="xml">
                <form string="Novedad PILA">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="Ej: Traslado a otra EPS o EOC (TAE)"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="code"/> 
                            </group>
                            <group>
                                </group>
                        </group>
                        <notebook>
                            <page string="Detalles de la Novedad">
                                <field name="description" placeholder="Describe cuándo y cómo debe usarse esta novedad en la PILA."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="action_pila_novelty_type" model="ir.actions.act_window">
            <field name="name">Tipos de Novedad PILA</field>
            <field name="res_model">pila.novelty.type</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Define y administra los códigos de novedades PILA (U, V, W, etc.) que se pueden aplicar a los contratos.
                </p>
            </field>
        </record>

        <menuitem 
            id="menu_pila_novelty_configuration"
            name="Novedades"
            parent="hr_payroll.menu_hr_payroll_global_settings"
            action="action_pila_novelty_type"
            sequence="20" 
        />


</odoo>