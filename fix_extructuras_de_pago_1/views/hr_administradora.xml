<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

  
    <record model="ir.ui.view" id="administradoras_lista">
      <field name="name">Administradoras list</field>
      <field name="model">hr.administradoras</field>
      <field name="arch" type="xml">
        <list>
          <field name="ccostos"/>
          <field name="administradora"/>
          <field name="name"/>
          <field name="company_id" invisible="1"/>
          <field name="tercero"/>
          <field name="porcentaje"/>
          <field name="compania"/>
          <field name="colaborador"/>
          <field name="centro_costos"/>
          <field name="cuenta_debito"/>
          <field name="cuenta_credito"/>

        </list>
      </field>
    </record>

  <record model="ir.ui.view" id="administradoras_forma">
      <field name="name">Administradoras form</field>
      <field name="model">hr.administradoras</field>
      <field name="arch" type="xml">
        <form>
          <group>
            <field name="name"/>
            <field name="company_id" invisible="1"/>
            <field name="ccostos" />
            <field name="administradora" string="Regla"/>
            <!-- attrs="{'invisible':[('centro_costos','=',True)]}" -->
            <field name="tercero" invisible= "centro_costos == True"/>  
            <field name="porcentaje"/>
            <field name="compania"/>
            <field name="colaborador"/>
            <field name="centro_costos"/>
            <field name="cuenta_debito"/>
            <field name="cuenta_credito"/>
          </group>
        </form>
      </field>
    </record>
  

  </data>
</odoo>