<odoo>
  <data>

  <record id="res_company_view" model="ir.ui.view">
        <field name="name">res.company.view</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[2]" position="after">
              <page string="Administradoras">
                  <group >
                    <field name="administradoras_ids" options="{'no_create': True, 'no_create_edit':True}" string="">
                    <list>
                    <field name="administradora"/>
                    <field name="name"/>
                    <field name="ccostos"/>
                </list>
                <form>
                  <group>
                  <field name="administradora"/>
                    <field name="name"/>
                    <field name="ccostos"/>
                </group>
                </form>
                </field>
                  </group>
              </page>
          </xpath>
        </field>
    </record>



  </data>
</odoo>